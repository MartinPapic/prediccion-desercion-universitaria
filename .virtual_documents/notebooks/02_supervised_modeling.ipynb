


%load_ext kedro.ipython
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import warnings
warnings.filterwarnings("ignore")





pca_model = catalog.load("pca_model")
X_train = catalog.load("X_train")
from sklearn.preprocessing import StandardScaler

num_cols = ["año_ingreso", "total_asignaturas", "promedio_general", "asistencia_general", "evaluaciones_totales"]
num_cols = [c for c in num_cols if c in X_train.columns]
X_num = X_train[num_cols].fillna(X_train[num_cols].median())
X_scaled = StandardScaler().fit_transform(X_num)

components = pca_model.transform(X_scaled)
plt.figure(figsize=(8,6))
plt.scatter(components[:, 0], components[:, 1], alpha=0.5, c="#3498db")
plt.xlabel("Componente Principal 1")
plt.ylabel("Componente Principal 2")
plt.title("PCA - Visualización de Estudiantes (Reducción de Dimensionalidad)")
plt.savefig("../results/plots/pca_visualizacion.png")
plt.show()





kmeans_model = catalog.load("clustering_model")
clusters = kmeans_model.predict(X_scaled)
plt.figure(figsize=(8,6))
scatter = plt.scatter(components[:, 0], components[:, 1], c=clusters, cmap="viridis", alpha=0.6)
plt.colorbar(scatter, label="Cluster")
plt.xlabel("Componente Principal 1")
plt.ylabel("Componente Principal 2")
plt.title("K-Means Clusters (Proyectados en PCA)")
plt.savefig("../results/plots/kmeans_clusters.png")
plt.show()
